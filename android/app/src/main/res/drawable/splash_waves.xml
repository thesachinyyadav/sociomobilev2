<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="360dp"
    android:height="150dp"
    android:viewportWidth="360"
    android:viewportHeight="150">

    <!-- Yellow Wave (right side) -->
    <!-- Rendered first to sit underneath the blue wave's left overlap -->
    <path
        android:fillColor="#FFC107"
        android:pathData="M 360,150 L 360,30 C 300,30 220,90 140,150 Z" />

    <!-- Blue Wave (left side) -->
    <path
        android:fillColor="#123B8C"
        android:pathData="M 0,150 L 0,10 C 120,10 200,70 280,150 Z" />

</vector>
